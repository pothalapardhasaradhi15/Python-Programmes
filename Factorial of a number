#Factorial of a number 
def factorial(n):
    s = 1

    if n < 0:
        print("Factorial does not exist for negative numbers")
    elif n == 0 or n == 1:
        print("Factorial is 1")
    else:
        for i in range(1, n + 1):
            s = s * i
        print("Factorial is", s)


factorial(5)

    
